{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "env": {
    "NEXTAUTH_URL": {
      "description": "NextAuth URL (e.g., https://yourdomain.vercel.app or https://yourdomain.com)",
      "required": true
    },
    "NEXTAUTH_SECRET": {
      "description": "NextAuth secret key for JWT signing (generate: openssl rand -hex 32)",
      "required": true
    },
    "NEXT_PUBLIC_API_URL": {
      "description": "Backend API URL (e.g., https://api.example.com/api or https://yourdomain.vercel.app/api)",
      "required": false
    }
  },
  "regions": ["iad1"],
  "functions": {
    "api/**": {
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "rewrites": [
    {
      "source": "/api/auth/:path*",
      "destination": "/api/auth/[...nextauth]"
    },
    {
      "source": "/api/students/:path*",
      "destination": "/api/students"
    },
    {
      "source": "/api/courses/:path*",
      "destination": "/api/courses"
    },
    {
      "source": "/api/enrollments/:path*",
      "destination": "/api/enrollments"
    }
  ],
  "headers": [
    {
      "source": "/:path(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        }
      ]
    },
    {
      "source": "/api/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
